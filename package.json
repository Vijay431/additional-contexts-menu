{
  "name": "additional-context-menus",
  "displayName": "Additional Context Menus",
  "description": "Enhanced right-click context menus for Node.js development - React, Angular, Express, Next.js, TypeScript & JavaScript with intelligent code operations.",
  "version": "2.0.0",
  "license": "MIT",
  "publisher": "VijayGangatharan",
  "icon": "logo.png",
  "author": {
    "name": "Vijay Gangatharan",
    "email": "vijayanand431@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vijay431/additional-contexts-menu.git"
  },
  "bugs": {
    "url": "https://github.com/Vijay431/additional-contexts-menu/issues"
  },
  "homepage": "https://github.com/Vijay431/additional-contexts-menu#readme",
  "packageManager": "pnpm@9.15.0",
  "keywords": [
    "context",
    "menu",
    "copy",
    "function",
    "react",
    "angular",
    "express",
    "nextjs",
    "typescript",
    "javascript",
    "nodejs",
    "productivity"
  ],
  "categories": [
    "Other"
  ],
  "engines": {
    "node": ">=20.0.0",
    "vscode": "^1.108.1"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "additionalContextMenus.copyFunction",
        "title": "Copy Function",
        "category": "Additional Context Menus",
        "icon": "$(symbol-function)"
      },
      {
        "command": "additionalContextMenus.copyContentToFile",
        "title": "Copy Content to File",
        "category": "Additional Context Menus",
        "icon": "$(copy)"
      },
      {
        "command": "additionalContextMenus.moveContentToFile",
        "title": "Move Content to File",
        "category": "Additional Context Menus",
        "icon": "$(arrow-right)"
      },
      {
        "command": "additionalContextMenus.saveAll",
        "title": "Save All",
        "category": "Additional Context Menus",
        "icon": "$(save-all)"
      },
      {
        "command": "additionalContextMenus.enable",
        "title": "Additional Context Menus: Enable",
        "category": "Additional Context Menus"
      },
      {
        "command": "additionalContextMenus.disable",
        "title": "Additional Context Menus: Disable",
        "category": "Additional Context Menus"
      },
      {
        "command": "additionalContextMenus.openInTerminal",
        "title": "Open in Terminal",
        "category": "Additional Context Menus",
        "icon": "$(terminal)"
      },
      {
        "command": "additionalContextMenus.copyFunctionToFile",
        "title": "Copy Function to File",
        "category": "Additional Context Menus",
        "icon": "$(copy)"
      },
      {
        "command": "additionalContextMenus.moveFunctionToFile",
        "title": "Move Function to File",
        "category": "Additional Context Menus",
        "icon": "$(arrow-right)"
      },
      {
        "command": "additionalContextMenus.generateEnum",
        "title": "Generate Enum from Union Type",
        "category": "Additional Context Menus",
        "icon": "$(symbol-enum)"
      },
      {
        "command": "additionalContextMenus.generateEnvFile",
        "title": "Generate .env File",
        "category": "Additional Context Menus",
        "icon": "$(file-code)"
      },
      {
        "command": "additionalContextMenus.generateCronTimer",
        "title": "Generate Cron Expression",
        "category": "Additional Context Menus",
        "icon": "$(clock)"
      },
      {
        "command": "additionalContextMenus.renameFileConvention",
        "title": "Rename File to Convention",
        "category": "Additional Context Menus",
        "icon": "$(edit)"
      }
    ],
    "configuration": {
      "title": "Additional Context Menus",
      "properties": {
        "additionalContextMenus.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Additional Context Menus extension"
        },
        "additionalContextMenus.autoDetectProjects": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect Node.js projects for context menu visibility"
        },
        "additionalContextMenus.supportedExtensions": {
          "type": "array",
          "default": [
            ".ts",
            ".tsx",
            ".js",
            ".jsx"
          ],
          "description": "File extensions where context menus will be shown"
        },
        "additionalContextMenus.copyCode.insertionPoint": {
          "type": "string",
          "enum": [
            "smart",
            "end",
            "beginning"
          ],
          "default": "smart",
          "description": "Where to insert copied code in target file"
        },
        "additionalContextMenus.copyCode.handleImports": {
          "type": "string",
          "enum": [
            "merge",
            "duplicate",
            "skip"
          ],
          "default": "merge",
          "description": "How to handle import statements when copying code"
        },
        "additionalContextMenus.copyCode.preserveComments": {
          "type": "boolean",
          "default": true,
          "description": "Preserve comments when copying code"
        },
        "additionalContextMenus.saveAll.showNotification": {
          "type": "boolean",
          "default": true,
          "description": "Show notification after saving all files"
        },
        "additionalContextMenus.saveAll.skipReadOnly": {
          "type": "boolean",
          "default": true,
          "description": "Skip read-only files when saving all"
        },
        "additionalContextMenus.terminal.type": {
          "type": "string",
          "enum": [
            "integrated",
            "external",
            "system-default"
          ],
          "default": "integrated",
          "description": "Type of terminal to open when using 'Open in Terminal' command"
        },
        "additionalContextMenus.terminal.externalTerminalCommand": {
          "type": "string",
          "default": "",
          "description": "Custom command for external terminal. Use {{directory}} as placeholder for directory path"
        },
        "additionalContextMenus.terminal.openBehavior": {
          "type": "string",
          "enum": [
            "parent-directory",
            "workspace-root",
            "current-directory"
          ],
          "default": "parent-directory",
          "description": "Which directory to open in terminal"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "when": "editorTextFocus && additionalContextMenus.enabled && additionalContextMenus.isNodeProject && resourceExtname =~ /\\.(ts|tsx|js|jsx)$/",
          "command": "additionalContextMenus.copyFunction",
          "group": "1_modification@1"
        },
        {
          "when": "editorTextFocus && additionalContextMenus.enabled && additionalContextMenus.isNodeProject && additionalContextMenus.isInFunction && resourceExtname =~ /\\.(ts|tsx|js|jsx)$/",
          "command": "additionalContextMenus.copyFunctionToFile",
          "group": "1_modification@1.1"
        },
        {
          "when": "editorTextFocus && additionalContextMenus.enabled && additionalContextMenus.isNodeProject && additionalContextMenus.isInFunction && resourceExtname =~ /\\.(ts|tsx|js|jsx)$/",
          "command": "additionalContextMenus.moveFunctionToFile",
          "group": "1_modification@1.2"
        },
        {
          "when": "editorTextFocus && editorHasSelection && additionalContextMenus.enabled && additionalContextMenus.isNodeProject",
          "command": "additionalContextMenus.copyContentToFile",
          "group": "1_modification@2"
        },
        {
          "when": "editorTextFocus && editorHasSelection && additionalContextMenus.enabled && additionalContextMenus.isNodeProject",
          "command": "additionalContextMenus.moveContentToFile",
          "group": "1_modification@3"
        },
        {
          "when": "editorTextFocus && additionalContextMenus.enabled",
          "command": "additionalContextMenus.saveAll",
          "group": "2_workspace@1"
        },
        {
          "when": "editorTextFocus && additionalContextMenus.enabled",
          "command": "additionalContextMenus.openInTerminal",
          "group": "2_workspace@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "additionalContextMenus.copyFunction",
        "key": "ctrl+alt+shift+f",
        "mac": "cmd+alt+shift+f",
        "when": "editorTextFocus && additionalContextMenus.enabled"
      },
      {
        "command": "additionalContextMenus.copyFunctionToFile",
        "key": "ctrl+alt+shift+e",
        "mac": "cmd+alt+shift+e",
        "when": "editorTextFocus && additionalContextMenus.enabled"
      },
      {
        "command": "additionalContextMenus.copyContentToFile",
        "key": "ctrl+alt+shift+c",
        "mac": "cmd+alt+shift+c",
        "when": "editorTextFocus && editorHasSelection && additionalContextMenus.enabled"
      },
      {
        "command": "additionalContextMenus.moveFunctionToFile",
        "key": "ctrl+alt+shift+r",
        "mac": "cmd+alt+shift+r",
        "when": "editorTextFocus && additionalContextMenus.enabled"
      },
      {
        "command": "additionalContextMenus.moveContentToFile",
        "key": "ctrl+alt+shift+m",
        "mac": "cmd+alt+shift+m",
        "when": "editorTextFocus && editorHasSelection && additionalContextMenus.enabled"
      },
      {
        "command": "additionalContextMenus.saveAll",
        "key": "ctrl+alt+shift+a",
        "mac": "cmd+alt+shift+a",
        "when": "additionalContextMenus.enabled"
      },
      {
        "command": "additionalContextMenus.openInTerminal",
        "key": "ctrl+alt+shift+t",
        "mac": "cmd+alt+shift+t",
        "when": "editorTextFocus && additionalContextMenus.enabled"
      }
    ]
  },
  "vsce": {
    "baseImageUrl": "./logo.png",
    "dependencies": false,
    "yarn": false
  },
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "tsx esbuild.config.ts --production",
    "build": "tsx esbuild.config.ts",
    "watch": "tsx esbuild.config.ts --watch",
    "package": "vsce package",
    "package:openvsx": "ovsx package",
    "publish": "vsce publish",
    "publish:openvsx": "ovsx publish",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint-staged": "lint-staged",
    "format": "prettier --write .",
    "test": "rm -rf dist && pnpm run build && pnpm run create-minimal && tsc -p ./tsconfig.test.json && HEADLESS=true node ./dist/test/e2e/runE2ETest.js",
    "test:all": "pnpm run lint && pnpm run build && pnpm run vscode:prepublish",
    "test:full": "rm -rf dist && pnpm run build && tsc -p ./tsconfig.test.json && SKIP_OPTIMIZATION=true node ./dist/test/e2e/runE2ETest.js",
    "test:minimal": "pnpm test",
    "test:clean": "rm -rf .vscode-test/minimal-extension .vscode-test/user-data-isolated .vscode-test/user-data-dev",
    "test:headless": "pnpm test",
    "test:headless:full": "SKIP_OPTIMIZATION=true pnpm run test:full",
    "test:ui": "HEADLESS=false pnpm test",
    "test:ci": "HEADLESS=true SKIP_OPTIMIZATION=false pnpm test",
    "create-minimal": "tsx scripts/create-minimal-extension.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@stylistic/eslint-plugin": "^5.7.1",
    "@types/fs-extra": "^11.0.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.30",
    "@types/vscode": "^1.108.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-mocha": "11.2.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^3.0.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.3",
    "lint-staged": "^15.2.11",
    "mocha": "^11.7.5",
    "ovsx": "^0.10.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
